    <!-- Lessons -->
    <string name="lesson_micro_contempt_title">Micro-Mépris</string>
    <string name="lesson_micro_contempt_desc">Un coin de la lèvre se relève d\'un seul côté. C\'est la seule expression faciale asymétrique, elle indique un sentiment de supériorité.</string>
    <string name="lesson_eye_block_title">Blocage Oculaire</string>
    <string name="lesson_eye_block_desc">Les yeux se ferment plus longtemps qu\'un simple clignement. C\'est un mécanisme de défense pour \"effacer\" une réalité dérangeante.</string>
    <string name="lesson_lip_compress_title">Compression des Lèvres</string>
    <string name="lesson_lip_compress_desc">Les lèvres forment une ligne droite. La personne retient quelque chose — une émotion ou une information.</string>
    <string name="lesson_neck_scratch_title">Grattage du Cou</string>
    <string name="lesson_neck_scratch_desc">La main gratte le côté du cou, sous l\'oreille. Un geste d\'auto-apaisement qui tente de ralentir le rythme cardiaque.</string>
    <string name="lesson_head_incongruence_title">Incongruence Tête-Message</string>
    <string name="lesson_head_incongruence_desc">La personne dit \"Oui\" mais sa tête fait un micro-mouvement de gauche à droite. Le corps dit la vérité avant le cerveau.</string>

